# NODE Research 텔레그램 브리핑 봇 + 실시간 이슈 봇
# 실제 값은 .env에 작성 (.env는 git에 올라가지 않음)

# === 공통 ===
ANTHROPIC_API_KEY=sk-ant-...

# === 텔레그램 ===
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHANNEL_ID=@noderesearch
TELEGRAM_ADMIN_CHAT_ID=               # Phase 0: /start 후 scripts/get_admin_chat_id.py로 취득

# === KIS API (한국투자증권) ===
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_IS_PAPER=false

# === 키움 REST API (52주 신고가 전용) ===
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=

# === DART API (전자공시) ===
DART_API_KEY=                         # Phase 0: opendart.fss.or.kr 회원가입 후 발급

# === 기타 데이터 ===
FINNHUB_API_KEY=
FMP_API_KEY=

# === 기존 브리핑 봇 ===
COMMENTARY_MODEL=claude-sonnet-4-20250514   # 시황 생성 모델 (sonnet 또는 opus)

# === 실시간 이슈 봇 (신규) ===
ISSUE_BOT_ENABLED=true                      # 전체 on/off (false면 스케줄 등록 생략)
ISSUE_BOT_AUTO_APPROVE=false                # 자동 승인 모드 (기본 OFF)

ISSUE_BOT_FILTER_MODEL=claude-haiku-4-5-20251001
ISSUE_BOT_GENERATOR_MODEL=claude-sonnet-4-6
ISSUE_BOT_PEER_MODEL=claude-sonnet-4-6
ISSUE_BOT_ENABLE_CACHING=true

ISSUE_BOT_POLL_INTERVAL_MIN=15              # 폴링 주기 (분)
ISSUE_BOT_URGENT_TIMEOUT_MIN=15
ISSUE_BOT_HIGH_TIMEOUT_MIN=45
ISSUE_BOT_NORMAL_TIMEOUT_MIN=120
ISSUE_BOT_EDIT_TIMEOUT_MIN=15
